{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

# Detect OS using chezmoi template variables
{{ if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "endeavouros") -}}
OS="arch"
INSTALL_CMD="sudo pacman -S --needed --noconfirm"
{{- else if eq .chezmoi.osRelease.id "debian" "ubuntu" }}
OS="debian"
INSTALL_CMD="sudo apt-get install -y"
{{- else }}
OS="unknown"
{{- end }}

echo "Detected OS: $OS"

if [[ "$OS" == "arch" ]]; then
  # Build list of pacman packages
  PACMAN_PKGS=()
  {{ range $name, $tool := .tools -}}
    {{ if index $tool "pacman" -}}
      PACMAN_PKGS+=({{ index $tool "pacman" | quote }})
    {{ end -}}
    {{ if index $tool "all" -}}
      PACMAN_PKGS+=({{ index $tool "all" | quote }})
    {{ end -}}
  {{ end -}}

  if [ ${#PACMAN_PKGS[@]} -gt 0 ]; then
    echo "Installing packages via pacman..."
    $INSTALL_CMD "${PACMAN_PKGS[@]}"
  fi

else
  # On Debian/Ubuntu, continue using brew and apt
  BREW_PKGS=()
  APT_PKGS=()
  
  {{ range $name, $tool := .tools -}}
    {{ if index $tool "brew" -}}
      BREW_PKGS+=({{ index $tool "brew" | quote }})
    {{ else if index $tool "all" -}}
      BREW_PKGS+=({{ index $tool "all" | quote }})
    {{ end -}}

    {{ if index $tool "apt" -}}
      APT_PKGS+=({{ index $tool "apt" | quote }})
    {{ end -}}
  {{ end -}}

  if command -v brew >/dev/null 2>&1; then
    if [ ${#BREW_PKGS[@]} -gt 0 ]; then
      echo "Using Homebrew for packages..."
      brew install "${BREW_PKGS[@]}"
    fi
  fi

  if [ ${#APT_PKGS[@]} -gt 0 ]; then
    echo "Installing packages via apt..."
    $INSTALL_CMD "${APT_PKGS[@]}"
  fi
fi

{{ end -}}
